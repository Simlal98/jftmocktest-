<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:version='2' class='v2' expr:dir='data:blog.languageDirection' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
  <meta content='width=device-width, initial-scale=1' name='viewport'/>
  <b:include data='blog' name='all-head-content'/>
  <title><data:blog.pageTitle/></title>

  <b:skin><![CDATA[
    body{font-family:'Segoe UI',Roboto,Arial,sans-serif;line-height:1.7;color:#222;background:#f9fafb;}
    a{color:#1e40af;text-decoration:none;}
    a:hover{color:#1e3a8a;}
    .header{background:#1e3a8a;color:white;padding:2rem 0;text-align:center;}
    .blog-title{font-size:2.6rem;font-weight:700;}
    .container{max-width:1280px;margin:25px auto;padding:0 15px;display:grid;grid-template-columns:2.6fr 1fr;gap:25px;}
    .post{background:#fff;border-radius:12px;padding:25px;margin-bottom:30px;box-shadow:0 4px 20px rgba(0,0,0,0.07);}
    .post-title{font-size:1.85rem;margin-bottom:12px;}
    @media (max-width:868px){.container{grid-template-columns:1fr;}}
  ]]></b:skin>
</head>
<body>

  <header class='header'>
    <b:section id='header' maxwidgets='1' showaddelement='yes'/>
  </header>

  <div class='container'>
    <main>
      <b:section id='main' preferred='yes' showaddelement='yes'/>
    </main>
    <aside>
      <b:section id='sidebar' preferred='yes' showaddelement='yes'/>
    </aside>
  </div>

</body>
</html>